{
  "tasks": {
    "status": "deno run -A src/x0100_dispatch.ts status",
    "audit:green": "deno run -A scripts/run_baseline.ts --green",
    "audit:strict": "deno run -A scripts/run_baseline.ts --strict",
    "fixture:phi": "deno run -A scripts/phi_roundtrip.ts",
    "fixture:phi:ingest-myc": "deno run -A scripts/phi_roundtrip.ts --ingest-myc",
    "submodules:status": "git submodule foreach 'git status --short --branch'",
    "submodules:update": "git submodule update --init --recursive",
    "check:myc": "cd myc && deno task check",
    "check:omega:rust": "cd omega && cargo test --workspace",
    "check:omega:deno": "cd omega && deno task test:fast",
    "check:liquid:audit": "cd liquid && deno task audit:strict",
    "check:liquid:doctor": "cd liquid && deno task ledger:doctor --json",
    "check:liquid:unit": "cd liquid && deno task test:unit",
    "ontology:coverage": "deno run -A tools/ontology_coverage.ts",
    "cognition:phase-report": "deno run -A tools/cognition_phase_report.ts",
    "cognition:snapshot": "deno run -A tools/cognition_snapshot.ts",
    "cognition:delta": "deno run -A tools/cognition_delta.ts",
    "cognition:recommend": "deno run -A tools/cognition_recommend.ts",
    "cognition:recommend-receipt": "deno run -A tools/cognition_recommend_receipt.ts",
    "cognition:recommend-to-chord": "deno run -A tools/recommend_to_chord.ts",
    "cognition:field": "deno run -A tools/cognition_field.ts",
    "validate:schemas": "deno run -A tools/validate_schemas.ts",
    "validate:schemas:strict": "deno run -A tools/validate_schemas.ts --strict",
    "validate:schemas:tracked": "deno run -A tools/validate_schemas.ts --tracked-only",
    "validate:schemas:tracked:strict": "deno run -A tools/validate_schemas.ts --tracked-only --strict",
    "cognition:cycle": "deno task cognition:snapshot && deno task cognition:delta && deno task cognition:recommend && deno task cognition:recommend-receipt && deno task cognition:recommend-to-chord && deno task cognition:field",
    "canon:verify": "deno run -A lib/canon/verify_vectors.ts",
    "chord:play": "deno run -A tools/chord_play.ts",
    "chord:block": "deno run --allow-net src/x4001_chord.ts block",
    "chord:init": "deno run --allow-net src/x4001_chord.ts init",
    "chord:translate": "deno run --allow-net src/x4001_chord.ts translate",
    "chord:parse": "deno run --allow-net src/x4001_chord.ts parse"
  }
}
